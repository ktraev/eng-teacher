# Copy this file to ".env" and fill in your key.
# Get a key at https://platform.openai.com/api-keys

OPENAI_API_KEY=sk-your-key-here

# Optional: change models if you like.
OCR_MODEL=gpt-4o
CHAT_MODEL=gpt-4o
STT_MODEL=whisper-1
TTS_MODEL=tts-1
TTS_VOICE=nova

# Port the server listens on.
PORT=3000

# --- Database ---
# If DATABASE_URL is set, folders are stored in Postgres (persistent, works on Render).
# Supabase: Project Settings -> Database -> Connection string -> URI.
#   Use the "Session pooler" string (IPv4-friendly) and put your real password in.
#   Example: postgresql://postgres.abcdefgh:YOURPASSWORD@aws-0-eu-central-1.pooler.supabase.com:5432/postgres
# DATABASE_URL=postgresql://...

# If DATABASE_URL is NOT set, folders are kept in a local file instead (data/folders.json).
# DATA_DIR=/Users/you/EnglishTeacherData
